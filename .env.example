# ─────────────────────────────────────────────────────────────────────────────
# Root .env template — copy to .env, then fill the marked values.
#   cp .env.example .env && docker compose up --build
# Loaded automatically by docker compose for ${VAR} interpolation and env_file.
# Values reconciled against the grading sheet (Required value column).
# ─────────────────────────────────────────────────────────────────────────────

# ── Simulation clock ─────────────────────────────────────────────────────────
SIMULATION_START_TIME=2026-06-20T00:00:00Z
GAME_SPEED=300

# ── Airport capacity / processing (game-seconds) ─────────────────────────────
EU_GATES=3
ALL_GATES=2
PROCESSING_TIME_EU=300
PROCESSING_TIME_ALL=600

# ── Service discovery URLs ───────────────────────────────────────────────────
# *_SERVICE_URL may be a comma-separated pool; the gateway round-robins it.
AIRPORT_SERVICE_URL=http://airport:3001
HOTEL_SERVICE_URL=http://hotel:3000
BROADCAST_SERVICE_URL=http://broadcast:3002
# Parrot pool — round-robin of 2 instances (per grading sheet).
PARROT_SERVICE_URL=http://parrot:3003,http://parrot-b:3003
DINING_SERVICE_URL=http://dining:3004

# ── Crowd Radar (broadcast service) ──────────────────────────────────────────
CROWD_POLL_INTERVAL_MS=5000
CROWD_CALM_MAX=0.34
CROWD_BUSY_MIN=0.67
AIRPORT_QUEUE_SOFT_CAP=10

# ── Parrot LLM config ────────────────────────────────────────────────────────
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY="API_KEY"            # <-- replace with the real OpenRouter/LLM key
LLM_MODEL=meta-llama/llama-3.1-8b-instruct
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=600
LLM_TOP_P=1.0
# PROFANITY_WORDS=damn,hell      # unset = curated built-in default

# ── Gateway ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
GATEWAY_CACHE_TTL=0
GATEWAY_RATE_LIMIT=0
GATEWAY_RATE_WINDOW=1m
INTERNAL_SECRET=
# JWT signing secret for /auth/guest and /auth/admin tokens. Falls back to
# INTERNAL_SECRET if unset. JWT_TTL is the token lifetime (default 12h).
JWT_SECRET=
JWT_TTL=12h

# ── Frontend (VITE_* — consumed as build args) ───────────────────────────────
VITE_GATEWAY_URL=http://localhost:8000
VITE_MOCK=false
VITE_ADMIN_PASSCODE=
VITE_TRAFFIC_GENERATOR=off
VITE_PARROT_CHAT_COOLDOWN_MS=30000
VITE_SIMULATION_START_TIME=2026-06-20T00:00:00Z
VITE_GAME_SPEED=300
# Gateway-side admin passcode (grading sheet row: gateway / ADMIN_PASSCODE).
# Paste the provided passcode after the '=' — keep the comment on its own line.
ADMIN_PASSCODE=

# ── Broadcast auth tokens — leave as-is for grading ──────────────────────────
FE_TOKEN=fe-token
HOTEL_TOKEN=hotel-token
BEACH_TOKEN=beach-token
AIRPORT_TOKEN=airport-token
PARROT_TOKEN=parrot-token

# ── Beach (Ktor) DB ──────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
JDBC_URL=jdbc:postgresql://postgres:5432/beach
DB_NAME=beach
DB_USER=postgres
DB_PASSWORD=postgres
APP_PORT=8080

# ── Hotel (Prisma) DB ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/hotel
